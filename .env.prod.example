# Camelify production environment
# Copy to .env on the VPS and fill in real values.

# ----- Web (Next.js) — baked into the build via Docker build args -----
NEXT_PUBLIC_SITE_URL=https://camelify.com
NEXT_PUBLIC_API_URL=https://api.camelify.com
NEXT_PUBLIC_DASHBOARD_URL=https://app.camelify.com

# ----- Dashboard (Vite) — baked into the build via Docker build args -----
VITE_API_URL=https://api.camelify.com
VITE_LANDING_URL=https://camelify.com

# ----- API (FastAPI) -----
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-me-with-32-byte-random
CORS_ORIGINS=["https://camelify.com","https://app.camelify.com"]

# Google OAuth — production credentials from console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.camelify.com/v1/auth/google/callback

# Where the API redirects users after sign-in
FRONTEND_URL=https://camelify.com
DASHBOARD_URL=https://app.camelify.com

# Where user-uploaded media is served from (CloudPanel reverse-proxies this)
MEDIA_PUBLIC_URL=https://api.camelify.com/media

# Admin access — JSON list of emails (case-insensitive)
ADMIN_EMAILS=["buildbeyondlimit1@gmail.com"]

# ----- Postgres -----
POSTGRES_USER=camelify
# Strong password: openssl rand -base64 24
POSTGRES_PASSWORD=replace-me-with-strong-password
POSTGRES_DB=camelify

# ----- Host paths for persistent data -----
# These are bind-mounted into the containers. Pick paths outside the repo.
MEDIA_HOST_PATH=/var/lib/camelify/media
POSTGRES_HOST_PATH=/var/lib/camelify/postgres

# ----- Localhost-only ports (CloudPanel reverse-proxies to these) -----
WEB_PORT=3007
DASHBOARD_PORT=3008
API_PORT=8007

# ----- Image tag (lets you do `make prod-deploy IMAGE_TAG=v1.2.3`) -----
IMAGE_TAG=latest
