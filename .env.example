# ----- Web (Next.js — marketing + storefront) -----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:5173
WEB_PORT=3000

# ----- Dashboard (Vite — creator app) -----
VITE_API_URL=http://localhost:8000
VITE_LANDING_URL=http://localhost:3000
DASHBOARD_PORT=5173

# ----- API (FastAPI) -----
API_PORT=8000
SECRET_KEY=please-change-me
# Must be false when using http://localhost OAuth (prod compose run locally).
# Auto-disabled when GOOGLE_REDIRECT_URI is http://, but set explicitly to be safe.
SESSION_COOKIE_SECURE=false

# ----- Google OAuth -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback

# ----- Frontend URLs (used by the API for post-OAuth redirects) -----
FRONTEND_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:5173

# ----- Postgres -----
POSTGRES_USER=camelify
POSTGRES_PASSWORD=camelify
POSTGRES_DB=camelify
POSTGRES_PORT=5432
