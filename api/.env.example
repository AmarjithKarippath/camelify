# App
APP_ENV=development
APP_NAME=Camelify API
CORS_ORIGINS=["http://localhost:3000","https://camelify.com"]

# Database (asyncpg DSN — note the +asyncpg)
DATABASE_URL=postgresql+asyncpg://camelify:camelify@localhost:5432/camelify

# Security (used by auth slice)
SECRET_KEY=change-me-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=604800
SESSION_COOKIE_NAME=cm_session
SESSION_COOKIE_SECURE=false

# Google OAuth (used by auth slice)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback

# Frontend URL (where to redirect after login)
FRONTEND_URL=http://localhost:3000
